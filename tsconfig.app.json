{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"outDir": "./out-tsc/app",
		"types": ["node"]
	},
	"files": ["src/main.ts", "src/main.server.ts", "src/server.ts"],
	"include": ["src/**/*.d.ts", "src/libs/ui/**/*.ts"],
	"angularCompilerOptions": {
		"extendedDiagnostics": {
			"checks": {
				"nullishCoalescingNotNullable": "suppress",
				"optionalChainNotNullable": "suppress"
			}
		}
	}
}
