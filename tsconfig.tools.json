{
	"compilerOptions": {
		"module": "Node16",
		"moduleResolution": "Node16",
		"target": "ES2022",
		"types": ["node"],
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"rootDir": "./src/tools",
		"outDir": "./dist/tools"
	},
	"include": ["src/tools/**/*"],
	"exclude": ["node_modules"]
}
