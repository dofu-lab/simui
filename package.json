		"karma-jasmine-html-reporter": "~2.1.0",
		"postcss": "^8.5.3",
		"prettier": "3.5.3",
		"prettier-plugin-organize-imports": "^4.1.0",
		"prettier-plugin-packagejson": "^2.5.10",
		"prettier-plugin-tailwindcss": "^0.6.11",
		"tailwind-merge": "^3.5.0",
		"tailwindcss-animate": "^1.0.6",
		"ts-node": "^10.9.2",
		"tslib": "^2.8.1",
