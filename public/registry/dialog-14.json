  "content": "import { Component, inject, viewChild } from '@angular/core';\nimport { FormBuilder, FormsModule, ReactiveFormsModule, Validators } from '@angular/forms';\nimport { HlmButton } from '@spartan-ng/helm/button';\nimport { HlmDialog, HlmDialogImports } from '@spartan-ng/helm/dialog';\nimport { HlmInput } from '@spartan-ng/helm/input';\nimport { HlmLabel } from '@spartan-ng/helm/label';\n\n@Component({\n\tselector: 'sim-dialog-14',\n\timports: [FormsModule, ReactiveFormsModule, HlmButton, HlmLabel, HlmInput, HlmButton, HlmDialogImports],\n\ttemplate: `\n\t\t<hlm-dialog>\n\t\t\t<button id=\"dialog-01-button\" hlmDialogTrigger hlmBtn variant=\"outline\">Sign Up</button>\n\t\t\t<hlm-dialog-content\n\t\t\t\tclass=\"top-1/2 left-1/2 max-h-[calc(100vh-2rem)] w-[400px] max-w-[calc(100%-2rem)] -translate-x-1/2 rounded-lg sm:max-h-[min(640px,80vh)] sm:max-w-[400px] sm:min-w-[400px]\"\n\t\t\t\t*hlmDialogPortal=\"let ctx\">\n\t\t\t\t<form [formGroup]=\"form\" (submit)=\"closeDialog()\">\n\t\t\t\t\t<div class=\"flex flex-col items-center gap-1\">\n\t\t\t\t\t\t<div class=\"flex shrink-0 items-center justify-center rounded-full border p-2\">\n\t\t\t\t\t\t\t<svg width=\"36\" height=\"36\" viewBox=\"0 0 36 36\" class=\"fill-primary\" xmlns=\"http://www.w3.org/2000/svg\">\n\t\t\t\t\t\t\t\t<g clip-path=\"url(#clip0_380_1629)\">\n\t\t\t\t\t\t\t\t\t<path\n\t\t\t\t\t\t\t\t\t\tfill-rule=\"evenodd\"\n\t\t\t\t\t\t\t\t\t\tclip-rule=\"evenodd\"\n\t\t\t\t\t\t\t\t\t\td=\"M8.47059 9C3.79241 9 0 12.7722 0 17.4255C0 22.0788 3.79241 25.8511 8.47059 25.8511H27.5294C32.2076 25.8511 36 22.0788 36 17.4255C36 12.7722 32.2076 9 27.5294 9H8.47059ZM4.23529 17.4255C4.23529 15.0989 6.1315 13.2128 8.47059 13.2128H27.5294C29.8685 13.2128 31.7647 15.0989 31.7647 17.4255C31.7647 19.7521 29.8685 21.6383 27.5294 21.6383H8.47059C6.1315 21.6383 4.23529 19.7521 4.23529 17.4255ZM6.35294 17.4255C6.35294 16.2622 7.30104 15.3191 8.47059 15.3191H27.1444C28.3139 15.3191 29.2621 16.2622 29.2621 17.4255C29.2621 18.